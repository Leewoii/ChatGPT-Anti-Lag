{
  "manifest_version": 3,
  "name": "ChatGPT Anti Lag",
  "version": "1.0",
  "description": "Limit visible chat messages in ChatGPT",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*"],

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ]
}